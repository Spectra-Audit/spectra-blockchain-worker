# Spectra Blockchain Worker environment variables
# Copy this file to `.env` and adjust values for your deployment.

# --- Blockchain RPC configuration ---
# Required: at least one HTTPS JSON-RPC endpoint used for historical polling.
# Provide a comma-separated list to enable automatic failover.
RPC_HTTP_URLS="https://eth.rpc.grove.city/v1/01fdb492","https://rpc.coinsdo.net/eth","https://ethereum.public.blockpi.network/v1/rpc/public","https://ethereum-rpc.publicnode.com"
# Optional: Single-endpoint fallback if you prefer to specify one provider.
# RPC_HTTP_URL="https://mainnet.infura.io/v3/PROJECT_ID"
# Optional: Comma-separated WebSocket endpoints for live subscriptions.
RPC_WS_URLS="wss://ethereum-rpc.publicnode.com","wss://0xrpc.io/eth","wss://mainnet.gateway.tenderly.co","wss://ethereum.callstaticrpc.com"

# --- Premium RPC Provider API Keys (Optional) ---
# These premium free-tier providers are tried first before falling back to public RPCs.
# Get free API keys from:
# - Infura: https://infura.io (free tier: 100k requests/day)
# - Alchemy: https://www.alchemy.com (free tier: 300M compute units/month)
# - QuickNode: https://www.quicknode.com (free tier: 2M requests/month)
# - Chainstack: https://chainstack.com (free tier: 2M requests/month)
# If not provided, the system will use public endpoints (which may be slower or less reliable).
# Optional: Infura project ID for Ethereum mainnet
INFURA_API_KEY="your-infura-project-id-here"
# Optional: Alchemy API key for Ethereum mainnet
ALCHEMY_API_KEY="your-alchemy-api-key-here"
# Optional: QuickNode endpoint URL (full URL with API key)
QUICKNODE_API_KEY="https://your-quicknode-endpoint-url"
# Optional: Chainstack access key (the XXXXX part from https://XXXXX.eth.chainstack.net)
CHAINSTACK_API_KEY="your-chainstack-access-key"

# --- Backend API authentication ---
# Required: Admin token used to authenticate with the Spectra backend API.
ADMIN_ACCESS_TOKEN="replace-with-admin-access-token"
# Required: Long-lived refresh token paired with the admin access token.
# Used to renew JWTs automatically when they expire.
ADMIN_REFRESH_TOKEN="replace-with-admin-refresh-token"
# Optional: Base URL for the Spectra backend API (defaults to http://localhost:8000/v1).
API_BASE_URL="http://localhost:8000/v1"

# --- ProjectScout configuration ---
# Optional: Minimum funding amount for projects to be included in scans
# PROJECT_MIN_FUNDING=10000.0
# Optional: Maximum funding amount for projects (leave unset for no limit)
# PROJECT_MAX_FUNDING=1000000.0
# Optional: Minimum number of backers for projects
# PROJECT_MIN_BACKERS=50
# Optional: Maximum number of backers (leave unset for no limit)
# PROJECT_MAX_BACKERS=10000
# Optional: Comma-separated list of categories to include
# PROJECT_CATEGORIES="AI/ML,DeFi,NFT"
# Optional: Comma-separated list of categories to exclude
# PROJECT_EXCLUDE_CATEGORIES="Scam,Low Quality"
# Optional: Minimum success rate (0.0-1.0)
# PROJECT_MIN_SUCCESS_RATE=0.5
# Optional: Maximum number of results to return
# PROJECT_MAX_RESULTS=100

# --- USDT Payment Monitor configuration ---
# Required: Target wallet address to monitor for USDT payments
# USDT_TARGET_WALLET="0x1234567890abcdef1234567890abcdef12345678"
# Optional: Comma-separated list of networks to monitor (ethereum, polygon, bsc, arbitrum, optimism, avalanche)
# USDT_NETWORKS="ethereum,polygon,bsc"
# Optional: Number of block confirmations to wait before processing payments
# USDT_CONFIRMATIONS=12
# Optional: Polling interval in seconds for checking new blocks
# USDT_POLL_INTERVAL=8
# Optional: Batch size for processing events
# USDT_BATCH_SIZE=1000
# Optional: Maximum block range to process in a single batch
# USDT_MAX_BLOCK_RANGE=50000
# Optional: Duration in days for pro subscription granted by payment
# USDT_PRO_TIER_DAYS=30
# Optional: Pro tier level to grant (1=basic, 2=advanced, 3=maximum)
# USDT_PRO_TIER_LEVEL=3

# --- Smart contract + chain settings ---
# Optional: Featured contract address tracked by both scouts (defaults shown).
CONTRACT_ADDRESS="0xe6733635aF5Ce7a1E022fbD87670EADa95397558"
# Staking contract for verifying user VERITAS LP staking status
# This is used by the /staking/verify endpoint to check user tier
VERITAS_STAKING_ADDRESS="0xe6733635aF5Ce7a1E022fbD87670EADa95397558"
# Optional: Explicit chain ID when signing transactions or requests.
# Leave unset to infer from the RPC provider.
# CHAIN_ID=1
# Optional: Override the starting block number (decimal or 0x-prefixed hex).
# Leave unset to follow the latest finalized block automatically.
# START_BLOCK=18000000

# --- Auxiliary services ---
# Optional: HTTP service that resolves project IDs to backend UUIDs.
# Only used by the Featured scout when seeding project metadata.
# PROJECT_ID_RESOLVER_URL="https://api.spectra.local/project-resolver"

# --- Database configuration ---
# Optional: Path to the shared SQLite database file for scout state.
# Defaults to `featured_scout.db` for the Featured scout and `pro_scout.db` for the Pro scout.
# DB_PATH="/var/lib/spectra/scout.db"
# Optional: Per-process override used by the combined `python -m scout run` CLI.
# SCOUT_DB_PATH="/var/lib/spectra/scout.db"

# --- Polling + reconciliation behaviour ---
# Optional: Seconds between polling iterations when reading from RPC (default: 8).
POLL_INTERVAL_SEC=8
# Optional: Number of block confirmations required before processing events (default: 5).
REORG_CONF=5
# Optional: Default tier assigned to users that lack a subscription (default: "free").
DEFAULT_USER_TIER="free"
# Optional: Comma-separated tiers that unlock Pro features.
PRO_TIER_SET="pro,enterprise"

# --- Logging ---
# Optional: Python logging level used by both scouts.
LOG_LEVEL="INFO"

# --- Token Holder Scout configuration ---
# Optional: Comma-separated list of tokens to track for weekly holder data collection
# Format: "address:chain_id" (defaults to chain_id 1 if not specified)
# TRACKED_TOKENS="0xdac17f958d2ee523a2206206994597c13d831ec7:1,0x55d398326f99059ff775485246999027b3197955:56"
# Optional: Day of week for holder data collection (0=Monday, 6=Sunday)
# HOLDER_COLLECTION_DAY=0
# Optional: Hour for holder data collection (0-23)
# HOLDER_COLLECTION_HOUR=2
# Optional: Number of top holders to fetch (default: 100)
# TOP_HOLDER_LIMIT=100

# --- Token Holder API Provider configuration ---
# Optional: NodeReal API key for holder data (free tier available)
# NODEREAL_API_KEY="your-nodereal-api-key"
# Optional: Moralis API key for holder data (free tier available)
# MORALIS_API_KEY="your-moralis-api-key"
# Optional: CoinGecko API key for holder data (free tier available)
# COINGECKO_API_KEY="your-coingecko-api-key"

# --- Audit Orchestrator configuration ---
# Optional: Enable/disable audit orchestrator (default: true)
# ENABLE_AUDIT_ORCHESTRATOR=true
# Optional: Port for audit webhook server (default: 8080)
# AUDIT_WEBHOOK_PORT=8080
# Optional: Host for audit webhook server (default: 0.0.0.0)
# AUDIT_WEBHOOK_HOST=0.0.0.0
# Optional: Secret for webhook authentication (recommended for production)
# AUDIT_BACKEND_WEBHOOK_SECRET="your-webhook-secret-key"

# --- Liquidity Analyzer configuration ---
# Optional: Enable/disable liquidity analyzer scout (default: false)
# ENABLE_LIQUIDITY_ANALYZER=true
# Optional: DexScreener API rate limit in requests per minute (default: 300)
# DEXSCREENER_RATE_LIMIT_RPM=300
